{
  "name": "Browser Cat",
  "description": "A virtual pet cat that lives in your browser and demands your attention!",
  "version": "1.0",
  "manifest_version": 3,
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "cat/config.js",
        "cat/idle.js",
        "cat/walk.js",
        "cat/activities.js",
        "cat/attention.js",
        "cat/petting.js",
        "cat/rage.js",
        "cat/keyboard.js",
        "cat/audio.js",
        "cat/ball.js",
        "cat/main.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage", "tabs"],
  "web_accessible_resources": [
    {
      "resources": ["sprites/*.png", "audio/*.ogg"],
      "matches": ["<all_urls>"]
    }
  ]
}
